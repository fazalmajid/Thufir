# PostgreSQL connection (required)
DATABASE_URL=postgresql://thufir:changeme@localhost:5432/thufir

# Server port (default: 3001)
PORT=3001

# WebAuthn / Passkey — must match the domain the app is served from.
# RP_ID is the hostname only (no port); RP_ORIGIN is the full origin.
# Dev defaults (localhost) are set automatically; only set for production.
RP_ID=thufir.majid.org
RP_ORIGIN=https://thufir.majid.org

# Set to "production" to enable Secure + HttpOnly cookies
GO_ENV=production
